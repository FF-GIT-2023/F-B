<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="table_reservation" name="Table Reservation">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-5">
                    <div class="card shadow-lg rounded-4">
                        <div class="card-body px-5 py-4">

                            <h2 class="text-center mb-3 text-primary fw-bold">Table Reservation</h2>

                            <t t-if="opening_hour and closing_hour">
                                <h5 class="text-center text-muted mb-4">
                                    <i class="bi bi-clock"></i>
                                    Opening Hours:
                                    <t t-esc="opening_hour"/>
                                    -
                                    <t t-esc="closing_hour"/>
                                </h5>
                            </t>

                            <form action="/restaurant/floors" method="post" enctype="multipart/form-data"
                                  class="needs-validation">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="row g-4 justify-content-center">
                                    <div class="col-md-4">
                                        <label for="date" class="form-label fw-semibold">Date</label>
                                        <input type="date" name="date" id="date" class="form-control" t-att-value="(datetime.datetime.now().date()).isoformat()"
                                            t-att-min="(datetime.datetime.now().date()).isoformat()" required="1"/>
                                    </div>

                                    <div class="col-md-4">
                                        <label for="time_slot" class="form-label fw-semibold">Time Slot</label>
                                        <select name="time_slot" id="time_slot" class="form-select" required="1">
                                            <t t-foreach="time_slots" t-as="slot">
                                                <option t-esc="slot"/>
                                            </t>
                                        </select>
                                    </div>
                                </div>

                                <div class="text-center mt-4">
                                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-sm">
                                        Submit
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>

                <!-- Modals -->
                <div class="modal fade" id="alert_modal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title">Invalid Date</h5>
                            </div>
                            <div class="modal-body">
                                <p>Please select a valid date.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary close_btn_alert_modal"
                                        data-bs-dismiss="modal">Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="time_alert_modal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title">Invalid Time</h5>
                            </div>
                            <div class="modal-body">
                                <p>Please select a valid booking start and end time.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary close_btn_time_alert_modal"
                                        data-bs-dismiss="modal">Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="open_hours_alert_modal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title">Invalid Time</h5>
                            </div>
                            <div class="modal-body">
                                <p>Select a time between the opening and closing hours.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary close_btn_time_alert_modal"
                                        data-bs-dismiss="modal">Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </t>
    </template>

    <!--  Template for floors  -->
    <template id="restaurant_floors" name="Admission Submit">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <div class="container swa_container card shadow-lg rounded-4 my-3 my-md-4">
                    <form action="/booking/confirm" method="POST" enctype="multipart/form-data" class="oe_import">
                        <div class="row align-items-center py-2 py-md-3 g-2">
                            <div class="col-12 col-md-3 col-lg-2">
                                <label class="font-weight-bold mb-0"><b>Select Floor</b></label>
                            </div>
                            <div class="col-12 col-md-5 col-lg-4">
                                <select name="floors" id="floors_rest" class="form-select form-select-sm select_floor">
                                    <option value="0">
                                        <b>Select a Floor</b>
                                    </option>
                                    <t t-foreach="floors" t-as="floor">
                                        <option t-att-value="floor.id">
                                            <t t-esc="floor.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>

                        <div id="legend_boxes" class="row justify-content-end mb-3" style="display:none;">
                            <div class="col-auto d-flex flex-wrap gap-3">
                                <div class="d-flex align-items-center">
                                    <div style="width: 20px; height: 20px; background-color: #c0392b; border-radius: 4px; border: 1px solid #ccc;"/>
                                    <span class="ms-2 small">Reserved</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div style="width: 20px; height: 20px; background-color: #27ae60; border-radius: 4px; border: 1px solid #ccc;"/>
                                    <span class="ms-2 small">Available</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div style="width: 20px; height: 20px; background-color: #2980b9; border-radius: 4px; border: 1px solid #ccc;"/>
                                    <span class="ms-2 small">Selected</span>
                                </div>
                            </div>
                        </div>

                        <div id="info" class="mx-0 mx-md-1 my-3" style="display:none;">
                            <div id="tableContainer" class="w-100 d-flex flex-column">

                                <div class="row g-2 mx-0" id="table_container_row"/>

                                <div id="booking_info" class="card shadow-sm rounded-3 w-100 my-2"
                                     style="display:none;background-color:#c8e0e0;border:0;">
                                    <div class="card-body p-2 p-md-3">
                                        <h5 class="card-title text-center mb-2 fs-5">
                                            <b>Booking Info</b>
                                        </h5>

                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered m-0">
                                                <tbody>
                                                    <tr>
                                                        <td class="fw-medium py-1 px-2">Date:</td>
                                                        <td class="text-end py-1 px-2" id="date_booking">
                                                            <t t-esc="date"/>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="fw-medium py-1 px-2">Start Time:</td>
                                                        <td class="text-end py-1 px-2" id="booking_start">
                                                            <t t-esc="start_time"/>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="fw-medium py-1 px-2">End Time:</td>
                                                        <td class="text-end py-1 px-2" id="booking_end">
                                                            <t t-esc="end_time"/>
                                                        </td>
                                                    </tr>
                                                    <t t-if="payment == 'True'">
                                                        <tr>
                                                            <td class="fw-medium py-1 px-2">
                                                                Booking Amount For
                                                                <span id="count_table">0</span>
                                                                Tables
                                                            </td>
                                                            <td class="text-end fw-bold py-1 px-2">
                                                                <span id="total_amount"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>

                                        <div class="mt-3">
                                            <div class="row g-2">
                                                <div class="col-12 col-md-6">
                                                    <div class="form-group mb-2">
                                                        <label for="name" class="form-label small fw-medium">Name:
                                                        </label>
                                                        <input type="text" class="form-control form-control-sm"
                                                               name="customer_name" id="name" required="1"/>
                                                    </div>
                                                </div>
                                                <div class="col-12 col-md-6">
                                                    <div class="form-group mb-2">
                                                        <label for="phone" class="form-label small fw-medium">Phone:
                                                        </label>
                                                        <input type="tel" class="form-control form-control-sm"
                                                               name="phone" id="phone" required="1"
                                                               pattern="[0-9]{10}" max="10" min="10"
                                                               inputmode="tel"
                                                               title="Enter a 10-digit phone number"/>
                                                    </div>
                                                </div>
                                                <div class="col-12 col-md-6">
                                                    <div class="form-group mb-2">
                                                        <label for="email" class="form-label small fw-medium">Email:
                                                        </label>
                                                        <input type="email" class="form-control form-control-sm"
                                                               name="email" id="email"/>
                                                    </div>
                                                </div>
                                                <div class="col-12 col-md-6">
                                                    <div class="form-group mb-2">
                                                        <label for="people" class="form-label small fw-medium">No. of
                                                            People:
                                                        </label>
                                                        <input type="number" class="form-control form-control-sm"
                                                               name="no_of_people" id="people" min="1" max="0" required="1"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-none">
                                            <input name="date" id="date_id" type="text" t-att-value="date"/>
                                            <input name="start_time" id="start_id" type="text"
                                                   t-att-value="start_time"/>
                                            <input name="end_time" id="end_id" type="text" t-att-value="end_time"/>
                                            <input name="tables" id="tables_input" type="text"/>
                                        </div>

                                        <div class="text-center mt-3">
                                            <button id="table_confirm" type="submit" disabled="true"
                                                    class="btn btn-primary btn-sm submit_button px-3 py-1 w-100 w-md-auto">
                                                Confirm Booking
                                            </button>
                                        </div>
                                    </div>

                                    <div style="line-height:1px;background: #ffffff;border:0;"/>
                                    <t t-if="payment">
                                        <div class="p-1 text-center small"
                                             style="background: #ffffff;border:0;color:#FF0000;">
                                            <t t-esc="refund"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

            </div>
        </t>
    </template>
</odoo>
