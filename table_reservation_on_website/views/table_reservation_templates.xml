<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <template id="table_reservation" name="Table Reservation">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-5">
                    <div class="card shadow-lg rounded-4">
                        <div class="card-body px-5 py-4">

                            <h2 class="text-center mb-3 text-primary fw-bold">Table Reservation</h2>

                            <t t-if="opening_hour and closing_hour">
                                <h5 class="text-center text-muted mb-4">
                                    <i class="bi bi-clock"></i>
                                    Opening Hours:
                                    <t t-esc="opening_hour"/>
                                    -
                                    <t t-esc="closing_hour"/>
                                </h5>
                            </t>

                            <form action="/restaurant/floors" method="post" enctype="multipart/form-data"
                                  class="needs-validation">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <div class="row g-4 justify-content-center">
                                    <div class="col-md-4">
                                        <label for="date" class="form-label fw-semibold">Date</label>
                                        <input type="date" name="date" id="date" class="form-control" required="1"/>
                                    </div>

                                    <div class="col-md-4">
                                        <label for="start_time" class="form-label fw-semibold">Start Time</label>
                                        <input type="time" name="start_time" id="start_time" class="form-control"
                                               required="1"/>
                                    </div>

                                    <div class="col-md-4">
                                        <label for="end_time" class="form-label fw-semibold">End Time</label>
                                        <input type="time" name="end_time" id="end_time" class="form-control"
                                               required="1"/>
                                    </div>
                                </div>

                                <div class="text-center mt-4">
                                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-sm">
                                        Submit
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>

                <!-- Modals -->
                <div class="modal fade" id="alert_modal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title">Invalid Date</h5>
                            </div>
                            <div class="modal-body">
                                <p>Please select a valid date.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary close_btn_alert_modal"
                                        data-bs-dismiss="modal">Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="time_alert_modal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title">Invalid Time</h5>
                            </div>
                            <div class="modal-body">
                                <p>Please select a valid booking start and end time.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary close_btn_time_alert_modal"
                                        data-bs-dismiss="modal">Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="open_hours_alert_modal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-warning text-dark">
                                <h5 class="modal-title">Invalid Time</h5>
                            </div>
                            <div class="modal-body">
                                <p>Select a time between the opening and closing hours.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary close_btn_time_alert_modal"
                                        data-bs-dismiss="modal">Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </t>
    </template>

    <!--  Template for floors  -->
    <template id="restaurant_floors" name="Admission Submit">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <div class="container swa_container card shadow-lg rounded-4 mt-4">
                    <br/>
                    <br/>
                    <form action="/booking/confirm" method="POST"
                          enctype="multipart/form-data" class="oe_import">
                        <div class="row">
                            <div class="col-2 mt-4">
                                <span><strong>Select Your Floor</strong></span>
                            </div>
                            <div class="col-2 mt-4" id="restaurant_floors">
                                <select name="floors" id="floors_rest"
                                        class="form-control">
                                    <option value="0">Select a Floor</option>
                                    <t t-foreach="floors" t-as="floor">
                                        <option t-att-value="floor.id">
                                            <t t-esc="floor.name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>
                        <br/>
                        <br/>
                        <br/>
                        <div id="info" class="ml-2" style="display: none;margin-right:20px">
                            <div id="tableContainer"
                                 style="width:100%;display:flex;">
                                <div class="row" id="table_container_row" style="margin-left:20px"/>
                                <div class="card shadow-lg rounded-4"
                                     style="background-color:#c8e0e0;width:1000px;height:370px;border:0;margin-left:20px">
                                    <div class="card-body" style="border:1px;">
                                        <h5 class="card-title text-center"
                                            style="Font-size:30px;">Booking Info
                                        </h5>
                                        <table class="table table-bordered table-striped" style="border:1px solid #000;">
                                            <tr>
                                                <td>Date:</td>
                                                <td style="text-align:right;"
                                                    id="date_booking">
                                                    <t t-esc="date"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Start Time:</td>
                                                <td style="text-align:right;"
                                                    id="booking_start">
                                                    <t t-esc="start_time"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>End Time:</td>
                                                <td style="text-align:right;"
                                                    id="booking_end">
                                                    <t t-esc="end_time"/>
                                                </td>
                                            </tr>
                                            <t t-if="payment == 'True'">
                                                <tr>
                                                    <td>
                                                        <b>
                                                            Booking Amount For
                                                            <span id="count_table">
                                                                0
                                                            </span>
                                                            Tables
                                                        </b>
                                                    </td>
                                                    <td style="text-align:right;">
                                                        <span id="total_amount"/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-else="">
                                                <tr style="display:none;">
                                                    <td>
                                                        <b>
                                                            Booking Amount For
                                                            <span id="count_table">
                                                                0
                                                            </span>
                                                            Tables
                                                        </b>
                                                    </td>
                                                    <td style="text-align:right;">
                                                        <span id="total_amount"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </table>
                                        <span hidden="hidden">
                                            <input name="date" id="date_id"
                                                   class="form-control border-0 p-0"
                                                   type="text"
                                                   data-allow-hotkeys="true"
                                                   t-att-value="date"
                                                   t-ref="autofocus"/>
                                            <input name="start_time"
                                                   id="start_id"
                                                   class="form-control border-0 p-0"
                                                   type="text"
                                                   data-allow-hotkeys="true"
                                                   t-att-value="start_time"
                                                   t-ref="autofocus"/>
                                            <input name="end_time"
                                                   class="form-control border-0 p-0"
                                                   type="text"
                                                   data-allow-hotkeys="true"
                                                   t-att-value="end_time"
                                                   t-ref="autofocus"/>
                                            <input name="tables"
                                                   id="tables_input"
                                                   class="form-control border-0 p-0"
                                                   type="text"
                                                   data-allow-hotkeys="true"
                                                   t-ref="autofocus"/>
                                        </span>
                                        <div class="text-center" style="margin-top:40px">
                                            <button type="submit" disabled="True"
                                                    class="btn btn-primary submit_button">
                                                Booking
                                                Confirm
                                            </button>
                                        </div>
                                    </div>
                                    <div style="line-height:1px;background: #ffffff;border:0;"/>
                                    <t t-if="payment">
                                        <div style="background: #ffffff;border:0;color:#FF0000;">
                                            <t t-esc="refund"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <br/>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>
